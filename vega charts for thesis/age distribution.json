{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "A bar chart with highlighting on hover and selecting on click. (Inspired by Tableau's interaction style.)",
  "data": {
    "values": [
      {
        "Age": "30-39",
        "Count": 17
      },
      {
        "Age": "40-49",
        "Count": 41
      },
      {
        "Age": "50-59",
        "Count": 46
      },
      {
        "Age": "60-69",
        "Count": 35
      },
      {
        "Age": "70-79",
        "Count": 8
      },
       {
        "Age": "80-89",
        "Count": 3
      },
      
    ]
  },
  "encoding": {
    "x": {
      "field": "Age",
      "type": "nominal"
    },
    "y": {
      "field": "Count",
      "type": "quantitative"
    }
  },
  //Layer propery allows to join multiple charts in a single chart 
  //"layer":[{},{}],

  "layer": [
    //Chart 1 for the text labels
    {
      "mark": {
        "type": "text",
        "align": "center",
        "fontSize": 14,
        "baseline": "line-bottom",
        "dx": 1
      },
      "encoding": {
        "text": {
          "field": "Count",
          "type": "ordinal"
        }
      }
    },
    //Chart 2 mark and encoding for the bar chart
    {
      "mark": {
        "type": "bar",
        "stroke": "black",
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
      "field": "Age",
      "type": "nominal",
      "axis": {
        "labelFontSize": 15,
        "titleFontSize": 20,
        
      },
      "scale": {
        "paddingInner": 0.2
      }
    },
    "y": {
      "field": "Count",
      "type": "quantitative",
      "axis": {
        "labelFontSize": 15,
        "titleFontSize": 20,
        
      }
    },


        "color": {
            "field": "Age",
            "type": "nominal",
            // legend field properties definition and customisable options
            "legend": {
                "title": "Age Distribution",
                "fillColor": "ghostwhite",
                "labelFontSize": 15,
        "titleFontSize": 20
            },
        },
      }
    }
  ]
}