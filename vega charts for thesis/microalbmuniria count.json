{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "A bar chart with highlighting on hover and selecting on click. (Inspired by Tableau's interaction style.)",
  "data": {
    "values": [
      {
        "Microalbuminuria": "Present",
        "Count": 118
      },
      {
        "Microalbuminuria": "Absent",
        "Count": 72
      },
      
    ]
  },
  "encoding": {
    "x": {
      "field": "Microalbuminuria",
      "type": "ordinal"
    },
    "y": {
      "field": "Count",
      "type": "quantitative"
    }
  },
  //Layer propery allows to join multiple charts in a single chart 
  //"layer":[{},{}],

  "layer": [
    //Chart 1 for the text labels
    {
      "mark": {
        "type": "text",
        "align": "center",
        "fontSize": 18,
        "baseline": "line-bottom",
        "dx": 1
      },
      "encoding": {
        "text": {
          "field": "Count",
          "type": "quantitative"
        }
      }
    },
    //Chart 2 mark and encoding for the bar chart
    {
      "mark": {
        "type": "bar",
        "color":"green",
        "stroke": "black",
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
          "field": "Microalbuminuria",
          "type": "ordinal",
          "axis": {
            "labelFontSize": 18,
            "titleFontSize": 20,
          },
          "scale": {
            "paddingInner": 0.1,
            "paddingOuter": 0.9
          }
        },
        "y": {
          "field": "Count",
          "type": "quantitative",
          "axis": {
            "labelFontSize": 18,
            "titleFontSize": 20,
            "labelAngle":0
          }
        },
        "color": {
            "field": "Microalbuminuria",
            "type": "nominal",
            // legend field properties definition and customisable options
            "legend": {
                "title": "Microalbuminuria",
                "fillColor": "azure",
                "labelFontSize": 15,
            "titleFontSize": 20
            },
            "scale": {
        "domain": ["Absent", "Present"],
        "range": ["orangered", "green"]
      }
        }
      }
    }

  ]
}